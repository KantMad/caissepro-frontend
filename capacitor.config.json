{
  "appId": "com.caissepro.app",
  "appName": "CaissePro",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "url": "https://caisse.techincash.app",
    "allowNavigation": ["*"]
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#2D5A3D",
      "showSpinner": false
    }
  }
}
